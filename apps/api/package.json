{
  "name": "@academy/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsc -p tsconfig.build.json && mkdir -p dist/modules/judge/runner && cp src/modules/judge/runner/sandboxRunner.cjs dist/modules/judge/runner/",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@academy/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.111.0",
    "@prisma/client": "^6.11.0",
    "argon2": "^0.43.0",
    "bullmq": "^5.80.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "socket.io": "^4.8.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@academy/eslint-config": "workspace:*",
    "@academy/tsconfig": "workspace:*",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.30.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.11.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
