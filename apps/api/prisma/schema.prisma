generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  displayName     String
  role            Role       @default(STUDENT)
  status          UserStatus @default(ACTIVE)
  avatarUrl       String?
  locale          String     @default("en")
  timezone        String     @default("UTC")
  emailVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  refreshTokens       RefreshToken[]
  authoredVersions    LessonVersion[]      @relation("AuthoredVersions")
  reviewedVersions    LessonVersion[]      @relation("ReviewedVersions")
  attempts            Attempt[]
  itemSubmissions     ItemSubmission[]
  enrollments         Enrollment[]
  progressRecords     ProgressRecord[]
  projectSubmissions  ProjectSubmission[]
  reviewedProjects    ProjectSubmission[]  @relation("ProjectReviewer")
  submissionMessages  SubmissionMessage[]
  xpTransactions      XpTransaction[]
  stats               UserStats?
  achievements        UserAchievement[]
  certificates        Certificate[]
  mentorConversations MentorConversation[]
  mentorUsage         MentorUsage[]
  revisionAssignments RevisionAssignment[]
  notifications       Notification[]
  emailMessages       EmailOutbox[]
  analyticsEvents     AnalyticsEvent[]

  @@map("users")
}

/// Opaque refresh tokens, stored as SHA-256 hashes. Tokens form rotation
/// "families": every login starts a family; each refresh creates a child row
/// and stamps the parent with replacedByTokenId. Presenting an already-replaced
/// token outside the grace window means the token leaked — the whole family is
/// revoked.
model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash         String    @unique
  familyId          String
  replacedByTokenId String?
  rotatedAt         DateTime?
  expiresAt         DateTime
  revokedAt         DateTime?
  ip                String?
  userAgent         String?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ─── Curriculum ──────────────────────────────────────────────────────────────
// Identity rows (Path/Module/Topic/Lesson) are stable: URLs, progress and
// gating point at them. Content lives on versions (LessonVersion/ContentBlock)
// so editing a draft never mutates what students are reading.

enum TopicDepth {
  AUTHORED
  OUTLINE
}

enum LessonVersionStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ContentBlockType {
  MARKDOWN
  CODE
  CALLOUT
  VIDEO
  IMAGE
  EMBED
}

model Path {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String  @default("")
  isActive    Boolean @default(true)

  modules     Module[]
  enrollments Enrollment[]

  @@map("paths")
}

model Module {
  id          String @id @default(cuid())
  pathId      String
  path        Path   @relation(fields: [pathId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String @default("")
  order       Int

  topics Topic[]

  @@unique([pathId, slug])
  @@unique([pathId, order])
  @@map("modules")
}

model Topic {
  id          String     @id @default(cuid())
  moduleId    String
  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String     @default("")
  order       Int
  depth       TopicDepth @default(OUTLINE)

  lessons      Lesson[]
  skills       Skill[]
  projectBrief ProjectBrief?

  @@unique([moduleId, slug])
  @@unique([moduleId, order])
  @@map("topics")
}

model Lesson {
  id               String @id @default(cuid())
  topicId          String
  topic            Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  slug             String
  title            String
  order            Int
  estimatedMinutes Int    @default(10)

  /// Denormalized pointer for one-hop published reads; maintained inside the
  /// publish transaction.
  currentPublishedVersionId String?        @unique
  currentPublishedVersion   LessonVersion? @relation("CurrentPublished", fields: [currentPublishedVersionId], references: [id])

  versions            LessonVersion[]
  skills              LessonSkill[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  assessment          Assessment?
  mentorConversations MentorConversation[]
  revisionTargets     RevisionAssignment[] @relation("RevisionTarget")

  @@unique([topicId, slug])
  @@unique([topicId, order])
  @@map("lessons")
}

/// A partial unique index (added in the migration by hand) additionally
/// guarantees at most one PUBLISHED version per lesson at the database level:
///   CREATE UNIQUE INDEX lesson_versions_one_published
///   ON lesson_versions ("lessonId") WHERE status = 'PUBLISHED';
model LessonVersion {
  id            String              @id @default(cuid())
  lessonId      String
  lesson        Lesson              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  versionNumber Int
  status        LessonVersionStatus @default(DRAFT)
  authorId      String
  author        User                @relation("AuthoredVersions", fields: [authorId], references: [id])
  reviewerId    String?
  reviewer      User?               @relation("ReviewedVersions", fields: [reviewerId], references: [id])
  changelog     String              @default("")
  reviewNotes   String              @default("")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  publishedAt   DateTime?
  archivedAt    DateTime?

  blocks             ContentBlock[]
  currentPublishedOf Lesson[]       @relation("CurrentPublished")

  @@unique([lessonId, versionNumber])
  @@index([lessonId, status])
  @@map("lesson_versions")
}

model ContentBlock {
  id                   String           @id @default(cuid())
  lessonVersionId      String
  lessonVersion        LessonVersion    @relation(fields: [lessonVersionId], references: [id], onDelete: Cascade)
  order                Int
  type                 ContentBlockType
  payload              Json
  payloadSchemaVersion Int              @default(1)

  @@unique([lessonVersionId, order])
  @@map("content_blocks")
}

/// Skills power adaptive learning (M8): lessons (and later assessment items)
/// are tagged; failed attempts map weak skills back to remedial lessons.
model Skill {
  id      String  @id @default(cuid())
  slug    String  @unique
  name    String
  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  lessons              LessonSkill[]
  assessmentItemSkills AssessmentItemSkill[]
  revisionAssignments  RevisionAssignment[]

  @@map("skills")
}

model LessonSkill {
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  skillId  String
  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([lessonId, skillId])
  @@map("lesson_skills")
}

// ─── Assessments ─────────────────────────────────────────────────────────────
// Assessments attach to stable identity rows (a Lesson for quizzes). Items are
// a type enum + validated JSON payload. Attempts freeze the full item payloads
// at start (itemsSnapshot), so editing items never changes how an in-flight or
// historical attempt is graded.

enum AssessmentKind {
  LESSON_QUIZ
  TOPIC_ASSESSMENT
  MODULE_EXAM
}

enum AssessmentItemType {
  MCQ
  MULTI_SELECT
  OUTPUT_PREDICTION
  REFLECTION
  CODING
  DEBUGGING
}

enum AttemptStatus {
  IN_PROGRESS
  GRADING
  GRADED
}

model Assessment {
  id              String         @id @default(cuid())
  kind            AssessmentKind @default(LESSON_QUIZ)
  lessonId        String?        @unique
  lesson          Lesson?        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title           String
  passingScorePct Int            @default(70)
  /// null = unlimited
  maxAttempts     Int?
  cooldownMinutes Int            @default(0)
  shuffleItems    Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items               AssessmentItem[]
  attempts            Attempt[]
  revisionAssignments RevisionAssignment[]

  @@map("assessments")
}

model AssessmentItem {
  id                   String             @id @default(cuid())
  assessmentId         String
  assessment           Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  order                Int
  type                 AssessmentItemType
  points               Int                @default(1)
  payload              Json
  payloadSchemaVersion Int                @default(1)

  skills AssessmentItemSkill[]

  @@unique([assessmentId, order])
  @@map("assessment_items")
}

model AssessmentItemSkill {
  itemId  String
  item    AssessmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([itemId, skillId])
  @@map("assessment_item_skills")
}

model Attempt {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId    String
  assessment      Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  attemptNumber   Int
  status          AttemptStatus @default(IN_PROGRESS)
  passed          Boolean?
  scorePct        Float?
  rawScore        Float?
  maxScore        Float?
  /// Full item payloads (including answer keys) frozen at attempt start.
  /// NEVER serialized to the client unsanitized.
  itemsSnapshot   Json
  /// Published lesson version the learner was reading when the quiz started.
  lessonVersionId String?
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  gradedAt        DateTime?

  submissions ItemSubmission[]

  @@unique([userId, assessmentId, attemptNumber])
  @@index([assessmentId, status])
  @@index([userId, assessmentId])
  @@map("attempts")
}

model ItemSubmission {
  id             String         @id @default(cuid())
  attemptId      String
  attempt        Attempt        @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  /// References the itemId inside the attempt's snapshot (not a live FK —
  /// the live item may be edited or deleted after the snapshot was taken).
  itemId         String
  answer         Json
  autoScore      Float?
  manualScore    Float?
  graderId       String?
  grader         User?          @relation(fields: [graderId], references: [id])
  graderFeedback String         @default("")
  gradedAt       DateTime?
  updatedAt      DateTime       @updatedAt
  executionRuns  ExecutionRun[]

  @@unique([attemptId, itemId])
  @@map("item_submissions")
}

// ─── Progress & gating ───────────────────────────────────────────────────────
// ProgressRecord is deliberately polymorphic (unitId is not a real FK): one
// table for lesson/topic/module progress beats three near-identical ones.
// Referential integrity for unitId is the application layer's job.

enum ProgressUnitType {
  LESSON
  TOPIC
  MODULE
}

enum ProgressStatus {
  IN_PROGRESS
  COMPLETED
}

model Enrollment {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathId     String
  path       Path     @relation(fields: [pathId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@id([userId, pathId])
  @@map("enrollments")
}

model ProgressRecord {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitType     ProgressUnitType
  unitId       String
  status       ProgressStatus
  bestScorePct Float?
  startedAt    DateTime         @default(now())
  completedAt  DateTime?
  updatedAt    DateTime         @updatedAt

  @@unique([userId, unitType, unitId])
  @@index([userId, status])
  @@map("progress_records")
}

/// Configurable gating: unit X requires unit Y (optionally at a minimum
/// score). Defaults are generated from curriculum order at seed time;
/// LOCKED/AVAILABLE are derived from these rules + completions at read time,
/// so there is no unlock state to corrupt — only completions to record.
model PrerequisiteRule {
  id               String           @id @default(cuid())
  unitType         ProgressUnitType
  unitId           String
  requiredUnitType ProgressUnitType
  requiredUnitId   String
  minScorePct      Int?

  @@unique([unitType, unitId, requiredUnitType, requiredUnitId])
  @@index([unitType, unitId])
  @@map("prerequisite_rules")
}

// ─── Coding challenges & the judge ──────────────────────────────────────────
// Challenges are referenced by CODING/DEBUGGING assessment items. At attempt
// start the full challenge (instructions, starter files, ALL test cases) is
// frozen into the attempt snapshot — the judge grades from the snapshot, so
// editing a challenge never changes how an in-flight attempt is scored.

enum ChallengeEnvironment {
  JS
  DOM
}

enum TestCaseKind {
  UNIT
  DOM
}

enum ExecutionStatus {
  QUEUED
  RUNNING
  PASSED
  FAILED
  TIMEOUT
  ERROR
}

model CodingChallenge {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  environment    ChallengeEnvironment
  instructionsMd String
  /// { "path": "content" } — what the student starts from.
  starterFiles   Json
  /// Reference solution; never serialized to clients or snapshots.
  solutionFiles  Json
  timeLimitMs    Int                  @default(5000)
  memoryLimitMb  Int                  @default(128)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  testCases TestCase[]

  @@map("coding_challenges")
}

model TestCase {
  id          String          @id @default(cuid())
  challengeId String
  challenge   CodingChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  order       Int
  name        String
  kind        TestCaseKind
  /// Test body: has `assert`/`assertEqual` in scope, plus the student code's
  /// globals (and `document` for DOM challenges).
  specCode    String
  weight      Int             @default(1)
  /// Hidden cases never leave the server (not even in sanitized snapshots).
  isHidden    Boolean         @default(false)
  timeoutMs   Int             @default(2000)

  @@unique([challengeId, order])
  @@map("test_cases")
}

/// One judge execution for one item submission. A submission can have many
/// runs (retries); the latest terminal run is authoritative for its score.
model ExecutionRun {
  id               String          @id @default(cuid())
  itemSubmissionId String
  itemSubmission   ItemSubmission  @relation(fields: [itemSubmissionId], references: [id], onDelete: Cascade)
  status           ExecutionStatus @default(QUEUED)
  submittedFiles   Json
  /// [{ testId, name, passed, message, hidden, weight, durationMs }]
  resultsJson      Json?
  stdout           String          @default("")
  errorMessage     String          @default("")
  durationMs       Int?
  judgeVersion     String          @default("1")
  createdAt        DateTime        @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?

  @@index([itemSubmissionId, createdAt])
  @@index([status])
  @@map("execution_runs")
}

// ─── Projects & machine coding ───────────────────────────────────────────────
// Topic-level project briefs with rubric definitions. Submissions are repo +
// demo URLs (bundle upload arrives with object storage); reviews follow
// PENDING → IN_REVIEW → CHANGES_REQUESTED | APPROVED with a feedback thread.

enum ProjectKind {
  MINI_PROJECT
  MACHINE_CODING
}

enum ReviewStatus {
  PENDING
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
}

model ProjectBrief {
  id        String      @id @default(cuid())
  topicId   String      @unique
  topic     Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  kind      ProjectKind
  title     String
  /// Full brief: goals, requirements, constraints (markdown).
  briefMd   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  rubric      RubricCriterion[]
  submissions ProjectSubmission[]

  @@map("project_briefs")
}

model RubricCriterion {
  id          String       @id @default(cuid())
  briefId     String
  brief       ProjectBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  description String       @default("")
  maxPoints   Int

  scores RubricScore[]

  @@unique([briefId, order])
  @@map("rubric_criteria")
}

/// One submission row per (user, brief): resubmissions update it in place;
/// the message thread preserves the review history.
model ProjectSubmission {
  id              String       @id @default(cuid())
  briefId         String
  brief           ProjectBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repoUrl         String
  demoUrl         String       @default("")
  notes           String       @default("")
  status          ReviewStatus @default(PENDING)
  submissionRound Int          @default(1)
  reviewerId      String?
  reviewer        User?        @relation("ProjectReviewer", fields: [reviewerId], references: [id])
  submittedAt     DateTime     @default(now())
  reviewedAt      DateTime?
  updatedAt       DateTime     @updatedAt

  scores   RubricScore[]
  messages SubmissionMessage[]

  @@unique([briefId, userId])
  @@index([status, submittedAt])
  @@map("project_submissions")
}

model RubricScore {
  submissionId String
  submission   ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  criterionId  String
  criterion    RubricCriterion   @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  points       Float
  comment      String            @default("")

  @@id([submissionId, criterionId])
  @@map("rubric_scores")
}

model SubmissionMessage {
  id           String            @id @default(cuid())
  submissionId String
  submission   ProjectSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User              @relation(fields: [authorId], references: [id])
  body         String
  createdAt    DateTime          @default(now())

  @@index([submissionId, createdAt])
  @@map("submission_messages")
}

// ─── Gamification ────────────────────────────────────────────────────────────
// XP is an append-only ledger with a unique idempotencyKey (a retried award
// is a no-op). UserStats is a denormalized projection updated in the same
// transaction as the ledger insert; the live leaderboard is a Redis ZSET that
// can be rebuilt from the ledger.

enum XpReason {
  LESSON_COMPLETED
  QUIZ_PASSED
  QUIZ_PASSED_FIRST_TRY
  PROJECT_APPROVED
  ACHIEVEMENT_EARNED
  STREAK_BONUS
}

model XpTransaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount         Int
  reason         XpReason
  /// Stable key derived from (reason, source) — makes awards idempotent.
  idempotencyKey String   @unique
  refType        String   @default("")
  refId          String   @default("")
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@map("xp_transactions")
}

/// Denormalized per-user projection of the ledger + streak state.
model UserStats {
  userId           String   @id
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalXp          Int      @default(0)
  level            Int      @default(1)
  currentStreak    Int      @default(0)
  longestStreak    Int      @default(0)
  /// The user-local calendar date (YYYY-MM-DD) of their last activity.
  lastActivityDate String   @default("")
  updatedAt        DateTime @updatedAt

  @@map("user_stats")
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  description String
  icon        String @default("EmojiEvents")
  xpReward    Int    @default(0)
  /// Ordering for display.
  order       Int    @default(0)

  earnedBy UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt      DateTime    @default(now())

  @@id([userId, achievementId])
  @@map("user_achievements")
}

enum CertificateScope {
  MODULE
  PATH
}

model Certificate {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope            CertificateScope
  /// moduleId or pathId depending on scope.
  scopeId          String
  scopeTitle       String
  serial           String           @unique
  /// Public, unguessable code for the verification page.
  verificationCode String           @unique
  issuedAt         DateTime         @default(now())

  @@unique([userId, scope, scopeId])
  @@map("certificates")
}

// ─── AI Mentor & adaptive learning ───────────────────────────────────────────
// The mentor streams via the Claude API. Conversations persist; MentorUsage
// enforces a per-user, per-day token budget. Grounding pulls only PUBLISHED
// lesson content — never assessment answer keys, hidden tests, or solutions.

enum MentorRole {
  USER
  ASSISTANT
}

model MentorConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("New conversation")
  /// Optional lesson the conversation is anchored to (for grounding).
  lessonId  String?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages MentorMessage[]

  @@index([userId, updatedAt])
  @@map("mentor_conversations")
}

model MentorMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   MentorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MentorRole
  content        String
  inputTokens    Int                @default(0)
  outputTokens   Int                @default(0)
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@map("mentor_messages")
}

/// One row per user per local day; enforces the daily token budget.
model MentorUsage {
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// YYYY-MM-DD in the user's timezone.
  day      String
  tokens   Int    @default(0)
  messages Int    @default(0)

  @@id([userId, day])
  @@map("mentor_usage")
}

enum RevisionStatus {
  ASSIGNED
  COMPLETED
}

/// Adaptive learning: a failed attempt maps weak skills to remedial lessons.
/// An open (ASSIGNED) row with blocksRetake gates the retake of its assessment.
model RevisionAssignment {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId   String
  assessment     Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  skillId        String
  skill          Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)
  targetLessonId String
  targetLesson   Lesson         @relation("RevisionTarget", fields: [targetLessonId], references: [id], onDelete: Cascade)
  status         RevisionStatus @default(ASSIGNED)
  blocksRetake   Boolean        @default(true)
  reason         String         @default("")
  createdAt      DateTime       @default(now())
  completedAt    DateTime?

  /// At most one open assignment per (user, assessment, skill).
  @@unique([userId, assessmentId, skillId])
  @@index([userId, status])
  @@map("revision_assignments")
}

// ─── Notifications, email outbox & analytics (M9) ────────────────────────────

enum NotificationType {
  QUIZ_PASSED
  QUIZ_FAILED
  ACHIEVEMENT_EARNED
  CERTIFICATE_ISSUED
  PROJECT_REVIEWED
  REVISION_ASSIGNED
  LESSON_UNLOCKED
}

/// In-app notification. Created by event subscribers; pushed live over
/// Socket.IO to the user's room and listed in the notification center.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  /// Optional in-app deep link, e.g. /lessons/:id or /achievements.
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum EmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

/// Transactional outbox: an intent row is written alongside the triggering
/// change and drained by a BullMQ worker (SMTP send). Mail is never sent
/// inside a request; a crash leaves a recoverable PENDING row, never a lost
/// or double-sent message.
model EmailOutbox {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  toEmail   String
  subject   String
  /// Template id the worker renders (welcome, certificate-issued, …).
  template  String
  /// JSON the template renders from.
  payload   Json
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?
  createdAt DateTime    @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
  @@map("email_outbox")
}

/// Append-only analytics stream. Batch-inserted from client + server; read
/// only through aggregation. occurredAt carries a BRIN index (added in the
/// migration) — cheap for an ever-growing, time-ordered table.
model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Dot-namespaced name, e.g. "lesson.opened", "quiz.submitted".
  name       String
  /// Free-form JSON properties (lessonId, assessmentId, scorePct, …).
  props      Json?
  /// Anonymous client session correlation.
  sessionId  String?
  occurredAt DateTime @default(now())

  @@index([name, occurredAt])
  @@map("analytics_events")
}
