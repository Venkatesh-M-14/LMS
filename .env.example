# Copy to apps/api/.env for local development.

# --- API ---
NODE_ENV=development
PORT=4000
API_ORIGIN=http://localhost:4000
WEB_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://academy:academy@localhost:5432/academy?schema=public
REDIS_URL=redis://localhost:6380

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-64-hex-chars
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_ROTATION_GRACE_SEC=30

SMTP_HOST=localhost
SMTP_PORT=1025

# Anthropic API key for the AI Mentor (used from Milestone 8 onward)
# ANTHROPIC_API_KEY=
