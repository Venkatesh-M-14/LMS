# Copy to apps/api/.env for local development.

# --- API ---
NODE_ENV=development
PORT=4000
API_ORIGIN=http://localhost:4000
WEB_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://academy:academy@localhost:5432/academy?schema=public
REDIS_URL=redis://localhost:6380

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-64-hex-chars
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_ROTATION_GRACE_SEC=30

SMTP_HOST=localhost
SMTP_PORT=1025

# Anthropic API key for the AI Mentor (used from Milestone 8 onward)
# ANTHROPIC_API_KEY=

# Rate limits (strict defaults for production; raise for local E2E runs)
# RATE_LIMIT_AUTH_PER_WINDOW=30
# RATE_LIMIT_GLOBAL_PER_MIN=300

# AI Mentor (Milestone 8). Set ANTHROPIC_API_KEY + MENTOR_PROVIDER=anthropic in prod.
# MENTOR_PROVIDER=fake              # deterministic, no key (dev/CI)
# ANTHROPIC_API_KEY=
# MENTOR_MODEL=claude-sonnet-5
# MENTOR_DAILY_TOKEN_BUDGET=50000
